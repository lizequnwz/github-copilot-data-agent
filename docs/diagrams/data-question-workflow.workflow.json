{
  "schema_version": 1,
  "diagram_type": "workflow",
  "meta": {
    "title": "Ask Data: Business Question to Validated Answer",
    "subtitle": "Promoted, derived, or allowlisted analysis with bounded Snowflake execution and reproducible reporting",
    "output": "docs/diagrams/data-question-workflow.html",
    "animation": "none"
  },
  "lanes": [
    { "id": "user", "label": "Business user" },
    { "id": "agent", "label": "Data agent" },
    { "id": "semantic", "label": "Approved semantic sources" },
    { "id": "snowflake", "label": "Read-only Snowflake" },
    { "id": "result", "label": "Validated result" },
    { "id": "exceptions", "label": "Clarification or model enhancement", "variant": "exception" }
  ],
  "phases": [
    { "id": "interpret", "label": "Interpret", "fromCol": 0, "toCol": 1 },
    { "id": "compile", "label": "Resolve + compile", "fromCol": 2, "toCol": 3, "variant": "security" },
    { "id": "execute", "label": "Execute", "fromCol": 4, "toCol": 4, "variant": "dashed" },
    { "id": "communicate", "label": "Communicate", "fromCol": 5, "toCol": 5, "variant": "emphasis" }
  ],
  "mainPath": [
    "question",
    "interpretation",
    "semantic_model",
    "compile_validate",
    "confirm_context",
    "execute_query",
    "check_rows",
    "answer_report"
  ],
  "nodes": [
    {
      "id": "question",
      "lane": "user",
      "col": 0,
      "type": "external",
      "label": "Ask question",
      "sublabel": "business outcome + output"
    },
    {
      "id": "interpretation",
      "lane": "agent",
      "col": 1,
      "type": "backend",
      "label": "Interpret",
      "sublabel": "metric / population / grain",
      "tag": "compact card"
    },
    {
      "id": "semantic_model",
      "lane": "semantic",
      "col": 2,
      "type": "database",
      "label": "Resolve source",
      "sublabel": "promoted / derived / ad hoc",
      "tag": "approved objects"
    },
    {
      "id": "compile_validate",
      "lane": "agent",
      "col": 3,
      "type": "security",
      "label": "Compile / validate",
      "sublabel": "formula / filters / order",
      "tag": "validate SQL"
    },
    {
      "id": "confirm_context",
      "lane": "user",
      "col": 4,
      "type": "security",
      "label": "Confirm",
      "sublabel": "non-secret settings",
      "tag": "first connection"
    },
    {
      "id": "execute_query",
      "lane": "snowflake",
      "col": 4,
      "type": "cloud",
      "label": "Execute query",
      "sublabel": "browser SSO + read-only",
      "tag": "max_rows + 1"
    },
    {
      "id": "check_rows",
      "lane": "result",
      "col": 4,
      "type": "security",
      "label": "Check result",
      "sublabel": "shape / grain / truncation"
    },
    {
      "id": "answer_report",
      "lane": "result",
      "col": 5,
      "type": "frontend",
      "label": "Answer",
      "sublabel": "definition / SQL / caveats",
      "tag": "optional report"
    },
    {
      "id": "clarify",
      "lane": "exceptions",
      "col": 1,
      "type": "messagebus",
      "label": "Clarify",
      "sublabel": "material business choice"
    },
    {
      "id": "enhance_model",
      "lane": "exceptions",
      "col": 3,
      "type": "messagebus",
      "label": "Narrow / enhance",
      "sublabel": "unsupported semantic operation",
      "width": 116
    },
    {
      "id": "recover",
      "lane": "exceptions",
      "col": 5,
      "type": "messagebus",
      "label": "Fix and retry",
      "sublabel": "config / SQL / result issue"
    }
  ],
  "edges": [
    { "from": "question", "to": "interpretation", "variant": "emphasis", "fromSide": "bottom", "toSide": "top", "route": "drop" },
    { "from": "interpretation", "to": "semantic_model", "variant": "emphasis", "fromSide": "bottom", "toSide": "top", "route": "drop" },
    { "from": "semantic_model", "to": "compile_validate", "variant": "emphasis", "fromSide": "top", "toSide": "bottom", "route": "drop" },
    { "from": "compile_validate", "to": "confirm_context", "variant": "emphasis", "fromSide": "top", "toSide": "bottom", "route": "drop" },
    { "from": "confirm_context", "to": "execute_query", "variant": "emphasis", "fromSide": "bottom", "toSide": "top", "route": "drop" },
    { "from": "execute_query", "to": "check_rows", "variant": "emphasis", "fromSide": "bottom", "toSide": "top", "route": "drop" },
    { "from": "check_rows", "to": "answer_report", "variant": "emphasis" },
    { "from": "interpretation", "to": "clarify", "label": "material ambiguity", "variant": "dashed", "role": "branch", "fromSide": "bottom", "toSide": "top", "route": "drop", "labelSegment": 1 },
    { "from": "compile_validate", "to": "enhance_model", "label": "unsupported", "variant": "security", "role": "branch", "fromSide": "bottom", "toSide": "top", "route": "drop", "labelAt": [430, 539] },
    { "from": "check_rows", "to": "recover", "label": "invalid", "variant": "security", "role": "error", "fromSide": "bottom", "toSide": "top", "route": "drop", "labelAt": [563, 663] }
  ],
  "cards": [
    {
      "dot": "cyan",
      "title": "Interpretation contract",
      "items": [
        "Show metric or formula, population, dimensions, filters, period, grain, source mode, and output",
        "Proceed without another approval when business definitions are unambiguous"
      ]
    },
    {
      "dot": "rose",
      "title": "Compiler + execution contract",
      "items": [
        "Preserve semantic grain and map it to unique SQL result aliases",
        "Compile parameterized filters and time bounds; fetch one extra row to prove truncation"
      ]
    },
    {
      "dot": "emerald",
      "title": "Inspectable answer",
      "items": [
        "Return period, grain, source mode, formula, query details, SQL, and caveats",
        "Label derived and ad hoc metrics unpromoted and keep them out of shared semantics"
      ]
    }
  ]
}
