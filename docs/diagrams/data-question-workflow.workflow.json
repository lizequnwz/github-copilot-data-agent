{
  "schema_version": 1,
  "diagram_type": "workflow",
  "meta": {
    "title": "Ask Data: Semantic Model to Exploration",
    "subtitle": "One model-first path with plan-driven iteration and optional result validation",
    "output": "docs/diagrams/data-question-workflow.html",
    "animation": "none"
  },
  "lanes": [
    { "id": "user", "label": "Analyst or product owner" },
    { "id": "agent", "label": "Data agent" },
    { "id": "semantic", "label": "Promoted semantic models" },
    { "id": "snowflake", "label": "Read-only Snowflake" },
    { "id": "workspace", "label": "Analysis workspace" },
    { "id": "assurance", "label": "Optional assurance" },
    { "id": "exceptions", "label": "Coverage gap", "variant": "exception" }
  ],
  "phases": [
    { "id": "ask", "label": "Ask", "fromCol": 0, "toCol": 0 },
    { "id": "resolve", "label": "Resolve model + plan", "fromCol": 1, "toCol": 2, "variant": "security" },
    { "id": "compile", "label": "Generate SQL", "fromCol": 3, "toCol": 3, "variant": "dashed" },
    { "id": "run", "label": "Run", "fromCol": 4, "toCol": 4, "variant": "dashed" },
    { "id": "explore", "label": "Explore + share", "fromCol": 5, "toCol": 5, "variant": "emphasis" }
  ],
  "mainPath": [
    "question",
    "semantic_model",
    "semantic_plan",
    "compile_sql",
    "confirm_context",
    "execute_query",
    "workspace",
    "answer"
  ],
  "nodes": [
    {
      "id": "question",
      "lane": "user",
      "col": 0,
      "type": "external",
      "label": "Ask question",
      "sublabel": "outcome or hypothesis"
    },
    {
      "id": "answer",
      "lane": "user",
      "col": 5,
      "type": "frontend",
      "label": "Finding / report",
      "sublabel": "model + SQL + caveats",
      "width": 110
    },
    {
      "id": "semantic_plan",
      "lane": "agent",
      "col": 2,
      "type": "backend",
      "label": "Build plan",
      "sublabel": "metric / dimensions / filters",
      "tag": "lightweight"
    },
    {
      "id": "compile_sql",
      "lane": "agent",
      "col": 3,
      "type": "backend",
      "label": "Compile SQL",
      "sublabel": "sources / joins / parameters",
      "tag": "model generated"
    },
    {
      "id": "semantic_model",
      "lane": "semantic",
      "col": 1,
      "type": "database",
      "label": "Select model",
      "sublabel": "promoted definitions",
      "tag": "always required"
    },
    {
      "id": "confirm_context",
      "lane": "user",
      "col": 4,
      "type": "security",
      "label": "Confirm context",
      "sublabel": "non-secret settings",
      "width": 110
    },
    {
      "id": "execute_query",
      "lane": "snowflake",
      "col": 4,
      "type": "cloud",
      "label": "Execute query",
      "sublabel": "read-only + bounded fetch"
    },
    {
      "id": "workspace",
      "lane": "workspace",
      "col": 5,
      "type": "frontend",
      "label": "Explore",
      "sublabel": "plan / table / chart / notebook",
      "tag": "iterate"
    },
    {
      "id": "validate_result",
      "lane": "assurance",
      "col": 5,
      "type": "security",
      "label": "Validate result",
      "sublabel": "grain / nulls / ranges",
      "tag": "optional",
      "width": 110
    },
    {
      "id": "semantic_setup",
      "lane": "exceptions",
      "col": 2,
      "type": "messagebus",
      "label": "Semantic Setup",
      "sublabel": "add field / join / metric",
      "tag": "no SQL bypass"
    }
  ],
  "edges": [
    { "from": "question", "to": "semantic_model", "variant": "emphasis", "fromSide": "bottom", "toSide": "top", "route": "drop" },
    { "from": "semantic_model", "to": "semantic_plan", "variant": "emphasis", "fromSide": "top", "toSide": "bottom", "route": "drop" },
    { "from": "semantic_plan", "to": "compile_sql", "variant": "emphasis" },
    { "from": "compile_sql", "to": "confirm_context", "variant": "emphasis", "fromSide": "top", "toSide": "bottom", "route": "drop" },
    { "from": "confirm_context", "to": "execute_query", "variant": "emphasis", "fromSide": "bottom", "toSide": "top", "route": "drop" },
    { "from": "execute_query", "to": "workspace", "variant": "emphasis", "fromSide": "bottom", "toSide": "top", "route": "drop" },
    { "from": "workspace", "to": "answer", "variant": "emphasis", "role": "return", "fromSide": "right", "toSide": "right", "route": "outside-right" },
    { "from": "workspace", "to": "validate_result", "label": "need assurance", "variant": "security", "role": "branch", "fromSide": "bottom", "toSide": "top", "route": "drop", "labelAt": [625, 663] },
    { "from": "validate_result", "to": "answer", "label": "checks pass", "variant": "emphasis", "role": "return", "fromSide": "right", "toSide": "right", "route": "outside-right", "labelSegment": 1 },
    { "from": "semantic_model", "to": "semantic_setup", "label": "coverage gap", "variant": "security", "role": "error", "fromSide": "bottom", "toSide": "top", "route": "drop", "labelSegment": 1 }
  ],
  "cards": [
    {
      "dot": "cyan",
      "title": "One semantic path",
      "items": [
        "Every Ask Data request selects a promoted model and semantic plan",
        "The compiler owns sources, joins, parameters, aliases, and SQL limits"
      ]
    },
    {
      "dot": "emerald",
      "title": "Exploration without bypass",
      "items": [
        "Edit dimensions, filters, time range, ordering, or a derived expression",
        "Notebook reruns regenerate SQL from the same semantic model"
      ]
    },
    {
      "dot": "rose",
      "title": "Progressive assurance",
      "items": [
        "Result checks are optional until the analysis needs more confidence",
        "Missing model coverage routes to Semantic Setup instead of arbitrary SQL"
      ]
    }
  ]
}
