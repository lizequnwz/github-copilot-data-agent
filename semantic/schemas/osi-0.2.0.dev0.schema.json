{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/open-semantic-interchange/ossie/core-spec/osi-schema.json",
  "title": "Open Semantic Interchange Core Metadata Specification",
  "type": "object",
  "required": ["version", "semantic_model"],
  "additionalProperties": false,
  "properties": {
    "version": {"const": "0.2.0.dev0"},
    "semantic_model": {"type": "array", "items": {"$ref": "#/$defs/model"}}
  },
  "$defs": {
    "expression": {
      "type": "object", "required": ["dialects"], "additionalProperties": false,
      "properties": {"dialects": {"type": "array", "minItems": 1, "items": {
        "type": "object", "required": ["dialect", "expression"], "additionalProperties": false,
        "properties": {"dialect": {"enum": ["ANSI_SQL", "SNOWFLAKE", "MDX", "TABLEAU", "DATABRICKS", "MAQL"]}, "expression": {"type": "string"}}
      }}}
    },
    "ai": {"oneOf": [{"type": "string"}, {"type": "object", "additionalProperties": true}]},
    "extension": {"type": "object", "required": ["vendor_name", "data"], "additionalProperties": false, "properties": {"vendor_name": {"type": "string"}, "data": {"type": "string"}}},
    "field": {
      "type": "object", "required": ["name", "expression"], "additionalProperties": false,
      "properties": {"name": {"type": "string"}, "expression": {"$ref": "#/$defs/expression"}, "dimension": {"type": "object", "additionalProperties": false, "properties": {"is_time": {"type": "boolean"}}}, "label": {"type": "string"}, "description": {"type": "string"}, "ai_context": {"$ref": "#/$defs/ai"}, "custom_extensions": {"type": "array", "items": {"$ref": "#/$defs/extension"}}}
    },
    "dataset": {
      "type": "object", "required": ["name", "source"], "additionalProperties": false,
      "properties": {"name": {"type": "string"}, "source": {"type": "string"}, "primary_key": {"type": "array", "items": {"type": "string"}}, "unique_keys": {"type": "array", "items": {"type": "array", "items": {"type": "string"}}}, "description": {"type": "string"}, "ai_context": {"$ref": "#/$defs/ai"}, "fields": {"type": "array", "items": {"$ref": "#/$defs/field"}}, "custom_extensions": {"type": "array", "items": {"$ref": "#/$defs/extension"}}}
    },
    "relationship": {
      "type": "object", "required": ["name", "from", "to", "from_columns", "to_columns"], "additionalProperties": false,
      "properties": {"name": {"type": "string"}, "from": {"type": "string"}, "to": {"type": "string"}, "from_columns": {"type": "array", "minItems": 1, "items": {"type": "string"}}, "to_columns": {"type": "array", "minItems": 1, "items": {"type": "string"}}, "ai_context": {"$ref": "#/$defs/ai"}, "custom_extensions": {"type": "array", "items": {"$ref": "#/$defs/extension"}}}
    },
    "metric": {
      "type": "object", "required": ["name", "expression"], "additionalProperties": false,
      "properties": {"name": {"type": "string"}, "expression": {"$ref": "#/$defs/expression"}, "description": {"type": "string"}, "ai_context": {"$ref": "#/$defs/ai"}, "custom_extensions": {"type": "array", "items": {"$ref": "#/$defs/extension"}}}
    },
    "model": {
      "type": "object", "required": ["name", "datasets"], "additionalProperties": false,
      "properties": {"name": {"type": "string"}, "description": {"type": "string"}, "ai_context": {"$ref": "#/$defs/ai"}, "datasets": {"type": "array", "minItems": 1, "items": {"$ref": "#/$defs/dataset"}}, "relationships": {"type": "array", "items": {"$ref": "#/$defs/relationship"}}, "metrics": {"type": "array", "items": {"$ref": "#/$defs/metric"}}, "custom_extensions": {"type": "array", "items": {"$ref": "#/$defs/extension"}}}
    }
  }
}
