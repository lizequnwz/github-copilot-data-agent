{
  "schema_version": 1,
  "diagram_type": "workflow",
  "meta": {
    "title": "Semantic Setup: Import, Review, and Promote",
    "subtitle": "Deterministic conversion, object-level refresh impact, guided decisions, and competency-gated promotion",
    "output": "docs/diagrams/semantic-layer-review.html",
    "animation": "none"
  },
  "lanes": [
    { "id": "business", "label": "Business reviewer" },
    { "id": "analyst", "label": "Data analyst" },
    { "id": "agent", "label": "Data agent + deterministic tools" },
    { "id": "artifacts", "label": "Versioned review and model artifacts" },
    { "id": "exceptions", "label": "Unresolved or failed validation", "variant": "exception" }
  ],
  "phases": [
    { "id": "intake", "label": "Intake", "fromCol": 0, "toCol": 1 },
    { "id": "generate", "label": "Generate + compare", "fromCol": 2, "toCol": 3, "variant": "dashed" },
    { "id": "review", "label": "Guided review", "fromCol": 4, "toCol": 4, "variant": "emphasis" },
    { "id": "promote", "label": "Promote", "fromCol": 5, "toCol": 5, "variant": "security" }
  ],
  "groups": [
    { "id": "business_decisions", "label": "Business view", "lane": "business", "fromCol": 4, "toCol": 4, "variant": "emphasis" },
    { "id": "analyst_decisions", "label": "Analyst view", "lane": "analyst", "fromCol": 4, "toCol": 4, "variant": "emphasis" },
    { "id": "audited_engine", "label": "Deterministic + audited", "lane": "agent", "fromCol": 2, "toCol": 5, "variant": "dashed" }
  ],
  "nodes": [
    {
      "id": "intake",
      "lane": "business",
      "col": 0,
      "type": "external",
      "label": "Setup intake",
      "sublabel": "domain / owner / questions"
    },
    {
      "id": "export",
      "lane": "analyst",
      "col": 1,
      "type": "external",
      "label": "Export + map",
      "sublabel": "BI metadata + sources"
    },
    {
      "id": "convert",
      "lane": "agent",
      "col": 2,
      "type": "backend",
      "label": "Convert",
      "sublabel": "deterministic + official schema"
    },
    {
      "id": "refresh_diff",
      "lane": "artifacts",
      "col": 3,
      "type": "database",
      "label": "Diff",
      "sublabel": "breaking / semantic / metadata",
      "width": 60
    },
    {
      "id": "business_review",
      "lane": "business",
      "col": 4,
      "type": "frontend",
      "label": "Review meaning",
      "sublabel": "scope / synonyms / examples",
      "tag": "guided controls"
    },
    {
      "id": "analyst_review",
      "lane": "analyst",
      "col": 4,
      "type": "frontend",
      "label": "Review sources",
      "sublabel": "sources / keys / joins / SQL",
      "tag": "guided controls"
    },
    {
      "id": "apply_validate",
      "lane": "agent",
      "col": 5,
      "type": "security",
      "label": "Apply gates",
      "sublabel": "Ossie / readiness / competency",
      "tag": "optional Snowflake"
    },
    {
      "id": "raw_artifacts",
      "lane": "artifacts",
      "col": 2,
      "type": "database",
      "label": "Raw + manifest",
      "sublabel": "repeatable source evidence"
    },
    {
      "id": "decisions",
      "lane": "artifacts",
      "col": 4,
      "type": "database",
      "label": "Decisions",
      "sublabel": "draft + audited operations",
      "width": 60
    },
    {
      "id": "confirm_target",
      "lane": "business",
      "col": 5,
      "type": "security",
      "label": "Confirm target",
      "sublabel": "explicit promotion destination"
    },
    {
      "id": "promoted_model",
      "lane": "artifacts",
      "col": 5,
      "type": "database",
      "label": "Promoted model",
      "sublabel": "semantic/models/*.yaml",
      "tag": "competency passed"
    },
    {
      "id": "needs_evidence",
      "lane": "exceptions",
      "col": 5,
      "type": "messagebus",
      "label": "Needs evidence",
      "sublabel": "draft and prior model retained",
      "tag": "no promotion"
    }
  ],
  "edges": [
    { "from": "intake", "to": "export", "variant": "emphasis", "fromSide": "bottom", "toSide": "top", "route": "drop" },
    { "from": "export", "to": "convert", "variant": "emphasis", "fromSide": "bottom", "toSide": "top", "route": "drop" },
    { "from": "convert", "to": "raw_artifacts", "variant": "dashed", "fromSide": "bottom", "toSide": "top", "route": "drop" },
    { "from": "convert", "to": "refresh_diff", "variant": "emphasis", "fromSide": "bottom", "toSide": "top", "route": "drop" },
    { "from": "refresh_diff", "to": "business_review", "variant": "emphasis", "fromSide": "top", "toSide": "bottom", "route": "up-channel" },
    { "from": "refresh_diff", "to": "analyst_review", "variant": "emphasis", "fromSide": "top", "toSide": "bottom", "route": "up-channel" },
    { "from": "business_review", "to": "decisions", "variant": "dashed", "fromSide": "left", "toSide": "bottom", "via": [[380, 119], [380, 530], [500, 530]] },
    { "from": "analyst_review", "to": "decisions", "variant": "dashed", "fromSide": "bottom", "toSide": "top", "route": "drop" },
    { "from": "decisions", "to": "confirm_target", "label": "review complete", "variant": "security", "fromSide": "bottom", "toSide": "right", "via": [[500, 540], [700, 540], [700, 119]], "labelAt": [650, 280] },
    { "from": "confirm_target", "to": "apply_validate", "variant": "emphasis", "fromSide": "bottom", "toSide": "top", "route": "drop" },
    { "from": "apply_validate", "to": "promoted_model", "variant": "emphasis", "fromSide": "bottom", "toSide": "top", "route": "drop" },
    { "from": "apply_validate", "to": "needs_evidence", "label": "blocked", "variant": "security", "role": "error", "fromSide": "right", "toSide": "right", "route": "outside-right", "labelSegment": 1 }
  ],
  "cards": [
    {
      "dot": "cyan",
      "title": "One guided review",
      "items": [
        "Business and Analyst filters expose different decisions over one draft",
        "Translation cards update executable expressions and provenance without raw JSON editing"
      ]
    },
    {
      "dot": "violet",
      "title": "Audited lifecycle",
      "items": [
        "Every item records rationale, evidence, confidence, assumptions, and before/after values",
        "Selected bulk decisions still emit one audited operation per semantic object"
      ]
    },
    {
      "dot": "emerald",
      "title": "Safe refresh + promotion",
      "items": [
        "Show object-level impact before review and reject stale decisions after regeneration",
        "Failed validation preserves drafts and the previously promoted model"
      ]
    }
  ]
}
